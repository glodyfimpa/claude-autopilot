{
  "description": "Autopilot quality gates: Stop hook runs test/lint/types/build, PreToolUse blocks dangerous operations",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/stop-gate.sh",
            "timeout": 300000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/pretool-gate.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
